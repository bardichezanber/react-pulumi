{
  "name": "@react-pulumi/core",
  "version": "0.1.0",
  "description": "React reconciler for Pulumi infrastructure-as-code",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bz/react-pulumi.git",
